---
import MainGridLayout from "@layouts/MainGridLayout.astro";
---

<MainGridLayout
  title="作品集 - 流转星(Betsy)"
  description="流转星(Betsy)的作品集合，涵盖 Unity 开发、网站项目、AI 应用等创作。"
>
  <h1 class="text-3xl font-bold mb-6 text-black/90 dark:text-white/90">作品集</h1>

  <div class="card-base rounded-[var(--radius-large)] p-8 md:p-12 text-center">
    <div class="text-5xl md:text-6xl mb-6">🚧</div>
    <h2 class="text-xl md:text-2xl font-bold mb-3 text-[var(--primary)]">作品集筹备中</h2>
    <p class="text-sm md:text-base text-black/60 dark:text-white/60 max-w-md mx-auto leading-relaxed">
      这里将展示我的 Unity 项目、网站作品与 AI 应用等创作。
      <br />
      内容正在整理中，敬请期待。
    </p>
  </div>
</MainGridLayout>
