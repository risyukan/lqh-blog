---
import { Icon } from "astro-icon/components";
import { type NavBarLink } from "../../types/config";
import { url } from "../../utils/url-utils";
import MusicPlayer from "../MusicPlayer.svelte";

type ResolvedNavBarGroup = { name: string; children: NavBarLink[] };
type NavItem = NavBarLink | ResolvedNavBarGroup;

function isGroup(item: NavItem): item is ResolvedNavBarGroup {
	return "children" in item;
}

interface Props {
	navItems: NavItem[];
}

const { navItems } = Astro.props;
---
<div id="nav-menu-panel" class:list={["float-panel float-panel-closed absolute transition-all fixed right-4 px-2 py-2"]}>
    <!-- 移动端音乐播放器 -->
    <div class="md:hidden flex items-center py-2 pl-3 pr-0 rounded-lg">
        <div class="transition text-black/75 dark:text-white/75 font-bold">背景音乐</div>
        <div class="flex-grow"></div>
        <div class="scale-[0.85] -mr-4">
            <MusicPlayer client:only="svelte" />
        </div>
    </div>
    {navItems.map((item) => {
        if (isGroup(item)) {
            return (
                <div class="nav-group">
                    <button type="button" class="nav-group-toggle w-full flex justify-between items-center py-2 pl-3 pr-1 rounded-lg gap-8
                        hover:bg-[var(--btn-plain-bg-hover)] active:bg-[var(--btn-plain-bg-active)] transition"
                    >
                        <div class="transition text-black/75 dark:text-white/75 font-bold">
                            {item.name}
                        </div>
                        <Icon name="material-symbols:keyboard-arrow-down-rounded"
                              class="nav-group-arrow transition text-[1.25rem] text-[var(--primary)] duration-200"
                        />
                    </button>
                    <div class="nav-group-children max-h-0 overflow-hidden transition-all duration-200">
                        {item.children.map((child) => (
                            <a href={child.external ? child.url : url(child.url)}
                               class="group flex justify-between items-center py-2 pl-6 pr-1 rounded-lg gap-8
                                   hover:bg-[var(--btn-plain-bg-hover)] active:bg-[var(--btn-plain-bg-active)] transition"
                               target={child.external ? "_blank" : null}
                            >
                                <div class="transition text-black/75 dark:text-white/75 font-bold group-hover:text-[var(--primary)] group-active:text-[var(--primary)]">
                                    {child.name}
                                </div>
                                {!child.external && <Icon name="material-symbols:chevron-right-rounded"
                                      class="transition text-[1.25rem] text-[var(--primary)]"
                                />}
                                {child.external && <Icon name="fa6-solid:arrow-up-right-from-square"
                                      class="transition text-[0.75rem] text-black/25 dark:text-white/25 -translate-x-1"
                                />}
                            </a>
                        ))}
                    </div>
                </div>
            );
        }
        return (
            <a href={item.external ? item.url : url(item.url)} class="group flex justify-between items-center py-2 pl-3 pr-1 rounded-lg gap-8
                hover:bg-[var(--btn-plain-bg-hover)] active:bg-[var(--btn-plain-bg-active)] transition
            "
               target={item.external ? "_blank" : null}
            >
                <div class="transition text-black/75 dark:text-white/75 font-bold group-hover:text-[var(--primary)] group-active:text-[var(--primary)]">
                    {item.name}
                </div>
                {!item.external && <Icon name="material-symbols:chevron-right-rounded"
                      class="transition text-[1.25rem] text-[var(--primary)]"
                />}
                {item.external && <Icon name="fa6-solid:arrow-up-right-from-square"
                      class="transition text-[0.75rem] text-black/25 dark:text-white/25 -translate-x-1"
                />}
            </a>
        );
    })}
</div>
